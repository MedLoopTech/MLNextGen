@inject IServiceScopeFactory ScopeFactory
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.DependencyInjection

<nav class="navbar navbar-expand-lg navbar-dark ml-navbar px-3">
    <a class="navbar-brand d-flex align-items-center" href="/">
        <span class="brand-mark" aria-hidden="true">M</span>
        MedLoop <span class="fw-light ms-1">NextGen</span>
    </a>

    @* The toggler was missing entirely in the first cut of this navbar,
       which made every nav link unreachable below the lg breakpoint. It
       needs Bootstrap's JS bundle (loaded in App.razor) to operate. *@
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
            aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav me-auto gap-lg-1">
            <AuthorizeView>
                <Authorized>
                    <li class="nav-item"><NavLink class="nav-link" href="/marketplace">Marketplace</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link" href="/bids/mine">My Bids</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link" href="/bids/incoming">Incoming Bids</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link" href="/orders/mine">Orders</NavLink></li>
                </Authorized>
            </AuthorizeView>
        </ul>

        <ul class="navbar-nav align-items-lg-center">
            <AuthorizeView>
                <Authorized>
                    <li class="nav-item">
                        <NavLink class="nav-link position-relative me-lg-2" href="/notifications" aria-label="Notifications">
                            <span aria-hidden="true">🔔</span>
                            @if (_unreadCount > 0)
                            {
                                <span class="notification-badge badge rounded-pill">
                                    @(_unreadCount > 9 ? "9+" : _unreadCount.ToString())
                                </span>
                            }
                        </NavLink>
                    </li>
                    <li class="nav-item me-lg-3 py-2 py-lg-0">
                        <span class="text-light opacity-75 small">@context.User.Identity?.Name</span>
                    </li>
                    <li class="nav-item">
                        <form method="post" action="/account/logout">
                            <AntiforgeryToken />
                            <button type="submit" class="btn btn-outline-light btn-sm">Log out</button>
                        </form>
                    </li>
                </Authorized>
                <NotAuthorized>
                    <li class="nav-item"><NavLink class="nav-link" href="/account/login">Log in</NavLink></li>
                    <li class="nav-item ms-lg-2">
                        <a class="btn btn-sm text-dark fw-semibold" style="background: var(--ml-accent);" href="/account/register">Register</a>
                    </li>
                </NotAuthorized>
            </AuthorizeView>
        </ul>
    </div>
</nav>

@code {
    private int _unreadCount;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
        {
            return;
        }

        var authState = await AuthState;
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            return;
        }

        try
        {
            // A dedicated scope, not the request's own AppDbContext: this
            // navbar renders alongside page components whose own queries can
            // interleave with this one during prerender, and a single scoped
            // DbContext instance does not allow two concurrent operations
            // ("a second operation was started on this context").
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();

            var userId = userManager.GetUserId(authState.User);
            if (userId is not null)
            {
                _unreadCount = await db.Notifications
                    .CountAsync(n => n.RecipientUserId == userId && !n.IsRead);
            }
        }
        catch
        {
            // The bell is auxiliary — a failed count must never take down
            // every page that renders the navbar. Worst case it shows no
            // badge until the next navigation.
            _unreadCount = 0;
        }
    }
}

<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(MainLayout)">
            <div class="ml-panel card mx-auto my-5" style="max-width: 480px;">
                <div class="card-body text-center py-5">
                    <div class="fs-1 mb-2" aria-hidden="true">🔍</div>
                    <h5 class="mb-2">Page not found</h5>
                    <p class="text-muted mb-3">The page you're looking for doesn't exist or may have moved.</p>
                    <a class="btn btn-primary" href="/">Back to home</a>
                </div>
            </div>
        </LayoutView>
    </NotFound>
</Router>

@page "/marketplace/{ProductId}"
@rendermode InteractiveServer
@attribute [Authorize]
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject INotificationService Notifications
@inject NavigationManager Nav
@using Microsoft.EntityFrameworkCore

<PageTitle>@(_product?.Name ?? "Product") — MedLoop NextGen</PageTitle>

@if (_loading)
{
    <LoadingIndicator Text="Loading listing…" />
}
else if (_product is null)
{
    <div class="ml-panel card">
        <EmptyState Icon="🔍" Title="Listing not found"
                    Subtitle="It may have been sold, withdrawn, or expired.">
            <a class="btn btn-primary btn-sm" href="/marketplace">Back to marketplace</a>
        </EmptyState>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/marketplace">Marketplace</a></li>
            <li class="breadcrumb-item active" aria-current="page">@_product.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="ml-panel card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h3 class="mb-0">@_product.Name</h3>
                        @if (_product.DaysUntilExpiry is int days and <= 90)
                        {
                            <span class="badge status-badge @(days <= 30 ? "text-bg-danger" : "text-bg-warning")">
                                Expires in @days days
                            </span>
                        }
                    </div>

                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted fw-normal">Seller</dt>
                        <dd class="col-sm-8">@(_product.Pharmacy?.Name ?? _product.PharmacyId)</dd>
                        <dt class="col-sm-4 text-muted fw-normal">Manufacturer</dt>
                        <dd class="col-sm-8">@(_product.Manufacturer ?? "—")</dd>
                        <dt class="col-sm-4 text-muted fw-normal">Dosage form</dt>
                        <dd class="col-sm-8">@(_product.DosageForm ?? "—")</dd>
                        <dt class="col-sm-4 text-muted fw-normal">Batch</dt>
                        <dd class="col-sm-8">@(_product.BatchNumber ?? "—")</dd>
                        <dt class="col-sm-4 text-muted fw-normal">Expiry</dt>
                        <dd class="col-sm-8">@(_product.ExpiryDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
                        <dt class="col-sm-4 text-muted fw-normal">Available quantity</dt>
                        <dd class="col-sm-8">@_product.AvailableQuantity units</dd>
                        <dt class="col-sm-4 text-muted fw-normal">List price</dt>
                        <dd class="col-sm-8 fw-semibold">@(_product.Price?.ToString("C") ?? "—") <span class="fw-normal text-muted">/ unit</span></dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            @if (_isOwnListing)
            {
                <div class="alert alert-info">This is your own pharmacy's listing.</div>
            }
            else if (_hasOpenBid)
            {
                <div class="alert alert-info">
                    You already have an open bid/negotiation on this listing — see <a href="/bids/mine" class="alert-link">My Bids</a>.
                </div>
            }
            else
            {
                <div class="ml-panel card">
                    <div class="card-header">Place a bid</div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(_error))
                        {
                            <div class="alert alert-danger" role="alert">@_error</div>
                        }
                        <EditForm Model="_form" OnValidSubmit="SubmitBid">
                            <div class="mb-3">
                                <label class="form-label">Quantity</label>
                                <InputNumber class="form-control" @bind-Value="_form.Quantity" min="1" max="@_product.AvailableQuantity" />
                                <div class="form-text">Up to @_product.AvailableQuantity units.</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Price per unit</label>
                                <div class="input-group">
                                    <InputNumber class="form-control" @bind-Value="_form.PricePerUnit" step="0.01" min="0.01" />
                                    <span class="input-group-text">/ unit</span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Message <span class="text-muted fw-normal">(optional)</span></label>
                                <InputTextArea class="form-control" rows="2" @bind-Value="_form.Message"
                                               placeholder="Anything the seller should know" />
                            </div>

                            <div class="d-flex justify-content-between border-top pt-3 mb-3">
                                <span class="text-muted">Offer total</span>
                                <span class="fw-bold">@((_form.Quantity * _form.PricePerUnit).ToString("C"))</span>
                            </div>

                            <button type="submit" class="btn btn-primary w-100" disabled="@_submitting">
                                @if (_submitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                                }
                                Send offer
                            </button>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public string ProductId { get; set; } = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private Product? _product;
    private bool _loading = true;
    private bool _isOwnListing;
    private bool _hasOpenBid;
    private bool _submitting;
    private string? _error;
    private readonly BidForm _form = new();

    private class BidForm
    {
        public int Quantity { get; set; } = 1;
        public double PricePerUnit { get; set; }
        public string? Message { get; set; }
    }

    private ApplicationUser? _user;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState!;
        _user = await UserManager.GetUserAsync(authState.User);

        _product = await Db.Products.Include(p => p.Pharmacy).FirstOrDefaultAsync(p => p.Id == ProductId);

        if (_product is not null && _user is not null)
        {
            _isOwnListing = _product.PharmacyId == _user.PharmacyId;

            _hasOpenBid = await Db.Bids.AnyAsync(b =>
                b.ProductId == ProductId &&
                b.BuyerPharmacyId == _user.PharmacyId &&
                (b.Status == BidStatus.Pending || b.Status == BidStatus.CounteredBySeller || b.Status == BidStatus.CounteredByBuyer));

            _form.PricePerUnit = _product.Price ?? 0;
            _form.Quantity = _product.AvailableQuantity;
        }

        _loading = false;
    }

    // Mirrors BidsController.Create's validation — see the README for why
    // this duplication exists for now (the portal calls the DbContext
    // directly rather than the REST API).
    private async Task SubmitBid()
    {
        if (_submitting)
        {
            return;
        }

        _error = null;

        if (_user?.PharmacyId is null || _product is null)
        {
            _error = "You must be registered as pharmacy staff to place a bid.";
            return;
        }

        if (_form.Quantity <= 0 || _form.PricePerUnit <= 0)
        {
            _error = "Quantity and price must be greater than zero.";
            return;
        }

        if (_form.Quantity > _product.AvailableQuantity)
        {
            _error = $"Only {_product.AvailableQuantity} units are available.";
            return;
        }

        _submitting = true;
        try
        {
            var bid = new Bid
            {
                ProductId = _product.Id,
                BuyerPharmacyId = _user.PharmacyId,
                BuyerUserId = _user.Id,
                OfferQuantity = _form.Quantity,
                OfferPricePerUnit = _form.PricePerUnit,
                Message = _form.Message,
                LastProposedBy = NegotiationParty.Buyer
            };

            Db.Bids.Add(bid);
            Db.BidNegotiationRounds.Add(new BidNegotiationRound
            {
                BidId = bid.Id,
                ProposedBy = NegotiationParty.Buyer,
                ProposedByUserId = _user.Id,
                Quantity = bid.OfferQuantity,
                PricePerUnit = bid.OfferPricePerUnit,
                Message = bid.Message
            });

            await Db.SaveChangesAsync();

            await Notifications.NotifyPharmacyAsync(
                _product.PharmacyId,
                "New bid received",
                $"A bid was placed on {_product.Name}: {bid.OfferQuantity} units at {bid.OfferPricePerUnit:C} each.");

            Nav.NavigateTo("/bids/mine");
        }
        finally
        {
            _submitting = false;
        }
    }
}

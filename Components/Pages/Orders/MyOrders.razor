@page "/orders/mine"
@rendermode InteractiveServer
@attribute [Authorize]
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject IPaymentGateway PaymentGateway
@inject INotificationService Notifications
@inject IConfiguration Configuration
@using Microsoft.EntityFrameworkCore

<PageTitle>Orders — MedLoop NextGen</PageTitle>

<div class="page-header mb-3">
    <h3 class="mb-1">Orders</h3>
    <p class="text-muted mb-0">Approved bids awaiting payment, plus your purchase and sales history.</p>
</div>

@if (_loading)
{
    <LoadingIndicator Text="Loading orders…" />
}
else
{
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger" role="alert">@_error</div>
    }

    <div class="ml-panel card mb-4">
        <div class="card-header">Ready to check out</div>
        @if (_approvedBids.Count == 0)
        {
            <EmptyState Icon="💳" Title="No approved bids awaiting payment"
                        Subtitle="When a negotiation is accepted, checkout appears here." />
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Price/unit</th>
                            <th class="text-end">Total</th>
                            <th class="text-end" style="min-width: 280px;">Checkout</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bid in _approvedBids)
                        {
                            <tr>
                                <td class="fw-semibold">@(bid.Product?.Name ?? bid.ProductId)</td>
                                <td class="text-end">@bid.OfferQuantity</td>
                                <td class="text-end">@bid.OfferPricePerUnit.ToString("C")</td>
                                <td class="text-end fw-semibold">@bid.TotalOfferValue.ToString("C")</td>
                                <td class="text-end">
                                    @if (_checkoutBidId == bid.Id)
                                    {
                                        <div class="input-group input-group-sm">
                                            <input class="form-control" placeholder="Promo code (optional)" @bind="_promoCode" />
                                            <button class="btn btn-success" disabled="@_busy" @onclick="() => Checkout(bid)">
                                                @if (_busy)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                                                }
                                                Confirm payment
                                            </button>
                                        </div>
                                        <div class="form-text text-start">
                                            The final total (incl. platform fee) is computed server-side at payment time.
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-success" disabled="@_busy" @onclick="() => _checkoutBidId = bid.Id">Checkout</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="ml-panel card mb-4">
        <div class="card-header">My purchases</div>
        @if (_buyerOrders.Count == 0)
        {
            <EmptyState Icon="🛒" Title="No purchases yet" />
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr><th>Product</th><th>Date</th><th class="text-end">Total</th><th>Status</th><th class="text-end"></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var order in _buyerOrders)
                        {
                            <tr>
                                <td class="fw-semibold">@(order.Product?.Name ?? order.ProductId)</td>
                                <td class="text-muted">@order.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">@order.TotalAmount.ToString("C")</td>
                                <td><StatusBadge Status="order.Status" /></td>
                                <td class="text-end"><a class="btn btn-sm btn-outline-primary" href="@($"/orders/{order.Id}")">View</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="ml-panel card">
        <div class="card-header">My sales</div>
        @if (_sellerOrders.Count == 0)
        {
            <EmptyState Icon="📈" Title="No sales yet"
                        Subtitle="Mark stock for redistribution to start receiving bids." />
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr><th>Product</th><th>Buyer</th><th>Date</th><th class="text-end">Total</th><th>Status</th><th class="text-end"></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var order in _sellerOrders)
                        {
                            <tr>
                                <td class="fw-semibold">@(order.Product?.Name ?? order.ProductId)</td>
                                <td>@(order.BuyerPharmacy?.Name ?? order.BuyerPharmacyId)</td>
                                <td class="text-muted">@order.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">@order.TotalAmount.ToString("C")</td>
                                <td><StatusBadge Status="order.Status" /></td>
                                <td class="text-end"><a class="btn btn-sm btn-outline-primary" href="@($"/orders/{order.Id}")">View</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private List<Bid> _approvedBids = new();
    private List<Order> _buyerOrders = new();
    private List<Order> _sellerOrders = new();
    private string? _checkoutBidId;
    private string _promoCode = string.Empty;
    private string? _error;
    private bool _loading = true;
    private bool _busy;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private ApplicationUser? _user;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState!;
        _user = await UserManager.GetUserAsync(authState.User);
        await Reload();
    }

    private async Task Reload()
    {
        if (_user?.PharmacyId is null)
        {
            _loading = false;
            return;
        }

        _approvedBids = await Db.Bids
            .Include(b => b.Product)
            .Where(b => b.BuyerPharmacyId == _user.PharmacyId && b.Status == BidStatus.Approved)
            .Where(b => !Db.Orders.Any(o => o.BidId == b.Id))
            .ToListAsync();

        _buyerOrders = await Db.Orders
            .Include(o => o.Product)
            .Where(o => o.BuyerPharmacyId == _user.PharmacyId)
            .OrderByDescending(o => o.CreatedAt)
            .ToListAsync();

        _sellerOrders = await Db.Orders
            .Include(o => o.Product)
            .Include(o => o.BuyerPharmacy)
            .Where(o => o.SellerPharmacyId == _user.PharmacyId)
            .OrderByDescending(o => o.CreatedAt)
            .ToListAsync();

        _loading = false;
    }

    // Mirrors OrdersController.Checkout — see the README on the known
    // duplication between the portal and the REST API for now.
    //
    // The _busy guard here is not cosmetic: this method charges the payment
    // gateway. Blazor Server queues a double-click as two sequential events,
    // and while the DB's unique index on Order.BidId would reject the second
    // order row, the second gateway charge would already have happened by
    // then. Refusing re-entry is the correct place to stop that.
    private async Task Checkout(Bid bid)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            _error = null;

            var freshBid = await Db.Bids.Include(b => b.Product).FirstAsync(b => b.Id == bid.Id);
            if (freshBid.Status != BidStatus.Approved)
            {
                _error = "Only approved bids can be paid for.";
                return;
            }

            if (await Db.Orders.AnyAsync(o => o.BidId == freshBid.Id))
            {
                _error = "This bid has already been paid for.";
                return;
            }

            PromoCode? promoCode = null;
            if (!string.IsNullOrWhiteSpace(_promoCode))
            {
                var normalized = _promoCode.Trim().ToUpperInvariant();
                promoCode = await Db.PromoCodes.FirstOrDefaultAsync(p => p.Code == normalized);
                if (promoCode is null || !promoCode.IsValidNow)
                {
                    _error = "That promo code is invalid, expired, or fully redeemed.";
                    return;
                }
            }

            var platformFeeRate = Configuration.GetValue("Marketplace:PlatformFeeRate", 0.0);
            var subtotal = freshBid.TotalOfferValue;
            var discountAmount = promoCode is null ? 0 : subtotal * (promoCode.DiscountPercent / 100.0);
            var discountedSubtotal = subtotal - discountAmount;
            var platformFeeAmount = discountedSubtotal * platformFeeRate;
            var totalAmount = discountedSubtotal + platformFeeAmount;

            var chargeResult = await PaymentGateway.ChargeAsync(new PaymentChargeRequest(
                _user!.PharmacyId!, totalAmount, "USD", $"MedLoop order for bid {freshBid.Id}"));

            if (!chargeResult.Succeeded)
            {
                _error = chargeResult.FailureReason ?? "Payment failed.";
                return;
            }

            await using var transaction = await Db.Database.BeginTransactionAsync();
            try
            {
                var product = await Db.Products.FirstAsync(p => p.Id == freshBid.ProductId);

                if (product.LockQuantity < freshBid.OfferQuantity || product.Quantity < freshBid.OfferQuantity)
                {
                    await transaction.RollbackAsync();
                    _error = "Product stock changed since this bid was approved. Contact the seller.";
                    return;
                }

                product.Quantity -= freshBid.OfferQuantity;
                product.LockQuantity -= freshBid.OfferQuantity;

                if (promoCode is not null)
                {
                    var freshPromo = await Db.PromoCodes.FirstAsync(p => p.Id == promoCode.Id);
                    if (!freshPromo.IsValidNow)
                    {
                        await transaction.RollbackAsync();
                        _error = "This promo code reached its redemption limit while checkout was processing.";
                        return;
                    }
                    freshPromo.TimesRedeemed += 1;
                }

                var order = new Order
                {
                    BidId = freshBid.Id,
                    ProductId = product.Id,
                    SellerPharmacyId = product.PharmacyId,
                    BuyerPharmacyId = freshBid.BuyerPharmacyId,
                    Quantity = freshBid.OfferQuantity,
                    UnitPrice = freshBid.OfferPricePerUnit,
                    PromoCodeId = promoCode?.Id,
                    DiscountAmount = discountAmount,
                    PlatformFeeRate = platformFeeRate,
                    PlatformFeeAmount = platformFeeAmount,
                    TotalAmount = totalAmount,
                    Status = OrderStatus.Paid,
                    PaymentReference = chargeResult.Reference
                };

                Db.Orders.Add(order);
                freshBid.Status = BidStatus.PaymentCompleted;

                await Db.SaveChangesAsync();
                await transaction.CommitAsync();

                await Notifications.NotifyPharmacyAsync(order.SellerPharmacyId, "Order paid",
                    $"An order for {product.Name} ({order.Quantity} units, {order.TotalAmount:C}) has been paid. Please prepare it for fulfillment.");
            }
            catch (DbUpdateException)
            {
                await transaction.RollbackAsync();
                _error = "This order could not be completed due to a concurrent update — please retry.";
                return;
            }

            _checkoutBidId = null;
            _promoCode = string.Empty;
            await Reload();
        }
        finally
        {
            _busy = false;
        }
    }
}

@page "/orders/{OrderId}"
@rendermode InteractiveServer
@attribute [Authorize]
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject INotificationService Notifications
@using Microsoft.EntityFrameworkCore

<PageTitle>Order — MedLoop</PageTitle>

@if (_loading)
{
    <p>Loading…</p>
}
else if (_order is null)
{
    <p>Order not found.</p>
}
else if (!_isParty)
{
    <p>You don't have access to this order.</p>
}
else
{
    <h3>Order — @(_order.Product?.Name ?? _order.ProductId)</h3>

    <dl class="row">
        <dt class="col-sm-3">Seller</dt><dd class="col-sm-9">@(_order.SellerPharmacy?.Name ?? _order.SellerPharmacyId)</dd>
        <dt class="col-sm-3">Buyer</dt><dd class="col-sm-9">@(_order.BuyerPharmacy?.Name ?? _order.BuyerPharmacyId)</dd>
        <dt class="col-sm-3">Quantity</dt><dd class="col-sm-9">@_order.Quantity</dd>
        <dt class="col-sm-3">Unit price</dt><dd class="col-sm-9">@_order.UnitPrice.ToString("C")</dd>
        @if (_order.DiscountAmount > 0)
        {
            <dt class="col-sm-3">Discount</dt><dd class="col-sm-9">-@_order.DiscountAmount.ToString("C")</dd>
        }
        <dt class="col-sm-3">Platform fee</dt><dd class="col-sm-9">@_order.PlatformFeeAmount.ToString("C")</dd>
        <dt class="col-sm-3">Total</dt><dd class="col-sm-9 fw-bold">@_order.TotalAmount.ToString("C")</dd>
        <dt class="col-sm-3">Status</dt><dd class="col-sm-9"><span class="badge bg-secondary">@_order.Status</span></dd>
    </dl>

    <a class="btn btn-outline-secondary mb-3" href="@($"/api/orders/{_order.Id}/invoice")" target="_blank">Download invoice (PDF)</a>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert alert-info">@_message</div>
    }

    <div class="d-flex gap-2 flex-wrap mb-4">
        @if (_isSeller && _order.Status == OrderStatus.Paid)
        {
            <button class="btn btn-success" @onclick="Fulfill">Mark fulfilled</button>
        }

        @if (_order.Status is OrderStatus.Paid or OrderStatus.Fulfilled)
        {
            <button class="btn btn-outline-danger" @onclick="() => _showDisputeForm = !_showDisputeForm">Raise a dispute</button>
        }

        @if (_order.Status == OrderStatus.Fulfilled && !_alreadyGaveFeedback)
        {
            <button class="btn btn-outline-primary" @onclick="() => _showFeedbackForm = !_showFeedbackForm">Leave feedback</button>
        }
    </div>

    @if (_showDisputeForm)
    {
        <div class="card mb-4"><div class="card-body">
            <label class="form-label">Dispute reason</label>
            <textarea class="form-control mb-2" @bind="_disputeReason"></textarea>
            <button class="btn btn-danger" @onclick="RaiseDispute">Submit dispute</button>
        </div></div>
    }

    @if (_showFeedbackForm)
    {
        <div class="card mb-4"><div class="card-body">
            <label class="form-label">Rating (1-5)</label>
            <input type="number" min="1" max="5" class="form-control mb-2" @bind="_feedbackRating" />
            <label class="form-label">Comment (optional)</label>
            <textarea class="form-control mb-2" @bind="_feedbackComment"></textarea>
            <button class="btn btn-primary" @onclick="SubmitFeedback">Submit feedback</button>
        </div></div>
    }

    @if (_feedback.Count > 0)
    {
        <h5>Feedback</h5>
        <ul class="list-group">
            @foreach (var f in _feedback)
            {
                <li class="list-group-item">
                    <strong>@f.SubmittedBy</strong>: @f.Rating/5 — @f.Comment
                </li>
            }
        </ul>
    }
}

@code {
    [Parameter]
    public string OrderId { get; set; } = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private Order? _order;
    private bool _loading = true;
    private bool _isParty;
    private bool _isBuyer;
    private bool _isSeller;
    private bool _alreadyGaveFeedback;
    private List<OrderFeedback> _feedback = new();

    private string? _message;
    private bool _showDisputeForm;
    private string _disputeReason = string.Empty;
    private bool _showFeedbackForm;
    private int _feedbackRating = 5;
    private string? _feedbackComment;

    private ApplicationUser? _user;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState!;
        _user = await UserManager.GetUserAsync(authState.User);
        await Reload();
    }

    private async Task Reload()
    {
        _order = await Db.Orders
            .Include(o => o.Product)
            .Include(o => o.SellerPharmacy)
            .Include(o => o.BuyerPharmacy)
            .FirstOrDefaultAsync(o => o.Id == OrderId);

        if (_order is not null && _user is not null)
        {
            _isBuyer = _user.PharmacyId == _order.BuyerPharmacyId;
            _isSeller = _user.PharmacyId == _order.SellerPharmacyId;
            _isParty = _isBuyer || _isSeller;

            _feedback = await Db.OrderFeedbacks.AsNoTracking().Where(f => f.OrderId == OrderId).ToListAsync();
            var myParty = _isBuyer ? OrderParty.Buyer : OrderParty.Seller;
            _alreadyGaveFeedback = _feedback.Any(f => f.SubmittedBy == myParty);
        }

        _loading = false;
    }

    private async Task Fulfill()
    {
        var fresh = await Db.Orders.FirstAsync(o => o.Id == OrderId);
        fresh.Status = OrderStatus.Fulfilled;
        fresh.FulfilledAt = DateTime.UtcNow;
        await Db.SaveChangesAsync();

        await Notifications.NotifyPharmacyAsync(fresh.BuyerPharmacyId, "Order fulfilled", "Your order has been marked as shipped/fulfilled by the seller.");

        _message = "Order marked as fulfilled.";
        await Reload();
    }

    private async Task RaiseDispute()
    {
        if (string.IsNullOrWhiteSpace(_disputeReason))
        {
            _message = "A reason is required.";
            return;
        }

        var fresh = await Db.Orders.FirstAsync(o => o.Id == OrderId);
        var party = _isBuyer ? OrderParty.Buyer : OrderParty.Seller;

        fresh.Status = OrderStatus.Disputed;
        fresh.DisputeRaisedBy = party;
        fresh.DisputeReason = _disputeReason;
        fresh.DisputeRaisedAt = DateTime.UtcNow;
        await Db.SaveChangesAsync();

        var notifyPharmacyId = party == OrderParty.Buyer ? fresh.SellerPharmacyId : fresh.BuyerPharmacyId;
        await Notifications.NotifyPharmacyAsync(notifyPharmacyId, "Order disputed", $"A dispute was raised on your order: {_disputeReason}");

        _showDisputeForm = false;
        _message = "Dispute submitted. An admin will review it.";
        await Reload();
    }

    private async Task SubmitFeedback()
    {
        if (_feedbackRating is < 1 or > 5)
        {
            _message = "Rating must be between 1 and 5.";
            return;
        }

        var party = _isBuyer ? OrderParty.Buyer : OrderParty.Seller;

        if (await Db.OrderFeedbacks.AnyAsync(f => f.OrderId == OrderId && f.SubmittedBy == party))
        {
            _message = "You've already submitted feedback for this order.";
            return;
        }

        var feedback = new OrderFeedback
        {
            OrderId = OrderId,
            SubmittedBy = party,
            SubmittedByPharmacyId = _user!.PharmacyId!,
            Rating = _feedbackRating,
            Comment = _feedbackComment
        };

        Db.OrderFeedbacks.Add(feedback);
        await Db.SaveChangesAsync();

        var order = await Db.Orders.FirstAsync(o => o.Id == OrderId);
        var notifyPharmacyId = party == OrderParty.Buyer ? order.SellerPharmacyId : order.BuyerPharmacyId;
        await Notifications.NotifyPharmacyAsync(notifyPharmacyId, "New feedback received", $"You received {_feedbackRating}/5 feedback on an order.");

        _showFeedbackForm = false;
        _message = "Feedback submitted.";
        await Reload();
    }
}
